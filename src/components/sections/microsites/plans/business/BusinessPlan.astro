---
import MicrositeLayout from '@/layouts/MicrositeLayout.astro';
import Navbar from '../components/Navbar.astro';
import SectionTitle from '../components/SectionTitle.astro';
import MicrositeFooter from '../components/MicrositeFooter.astro';
import HeroCarousel from './components/HeroCarousel';
import ProductCard from './components/ProductCard.astro';
import BannerSection from './components/BannerSection.astro';

import type {
  BusinessMicrositeConfig,
  ProductItem,
  BusinessEventItem,
  BusinessBannerTheme,
  BusinessProductCardTheme,
  BusinessProductCardCtaTheme,
  BusinessHeroCtaTheme,
  BusinessHeroTextTheme,
} from './types';

interface Props {
  config: BusinessMicrositeConfig;
}

const { config } = Astro.props;

const { brand, meta, branding, navigation, sections, footer } = config;

const {
  primaryColor,
  accentColor,
  buttonColor,
  buttonHoverColor,
  buttons,
  surfaces,
  footer: footerTheme,
} = branding.theme;
const productCardTheme: BusinessProductCardTheme = surfaces?.productCard ?? {
  featuredBackground: '#20252E',
  defaultBackground: '#303640',
  textColor: '#FFFFFF',
};
const productCardCtaTheme: BusinessProductCardCtaTheme = buttons?.productCardCta ?? {
  background: '#FFFFFF',
  textColor: accentColor,
  hoverBackground: '#E2E8F0',
  hoverTextColor: accentColor,
  borderColor: 'transparent',
  hoverBorderColor: 'transparent',
};
const heroCtaTheme: BusinessHeroCtaTheme = buttons?.heroCta ?? {
  background: buttonColor,
  textColor: '#FFFFFF',
  hoverBackground: buttonHoverColor,
  hoverTextColor: '#FFFFFF',
  borderColor: accentColor,
  hoverBorderColor: accentColor,
};
const heroTextTheme: BusinessHeroTextTheme = branding.theme.hero?.text ?? {
  titleColor: '#FFFFFF',
  subtitleColor: '#FFFFFF',
  descriptionColor: 'rgba(255, 255, 255, 0.9)',
  sliderTitleColor: '#FFFFFF',
  sliderSubtitleColor: '#FFFFFF',
  sliderActiveBorderColor: '#FFFFFF',
};
const bannerTheme: BusinessBannerTheme = branding.theme.banner ?? {
  titleColor: '#FFFFFF',
  descriptionColor: '#FFFFFF',
  overlayBackground: 'rgba(0, 0, 0, 0.1)',
};

const heroItems = sections.heroes;
---

<MicrositeLayout title={meta.title} description={meta.description} favicon={meta.favicon}>
  <Navbar logo={branding.logos.header} basePath={navigation.basePath} items={navigation.items} />

  <div class="px-3 md:px-5">
    <HeroCarousel
      heroes={heroItems}
      theme={{ buttonColor, buttonHoverColor, accentColor, heroCta: heroCtaTheme, heroText: heroTextTheme }}
      buttonBorder={accentColor}
      client:load
    />
  </div>

  <section>
    <SectionTitle color={primaryColor}>
      {sections.products.sectionTitle}
    </SectionTitle>

    <div class="products-grid max-w-7xl mx-auto px-10 grid md:grid-cols-2 gap-5 mb-5">
      {
        sections.products.items.map((item: ProductItem, index: number) => (
          <ProductCard
            {...item}
            accentColor={accentColor}
            buttonText={sections.products.buttonText}
            index={index}
            productCardTheme={productCardTheme}
            productCardCtaTheme={productCardCtaTheme}
          />
        ))
      }
    </div>
  </section>

  {
    sections.video?.enabled && (
      <section class="grid place-items-center mb-5 scrolling-section">
        <iframe
          class="w-full h-[70dvh]"
          src={sections.video.url}
          title={sections.video.title}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        />
      </section>
    )
  }

  <BannerSection {...sections.products.bannerProduct} brandName={brand.name} bannerTheme={bannerTheme} />

  <section class="catalogue-section scrolling-section">
    <div class="flex flex-col lg:flex-row justify-between">
      <div class="catalogue-text flex flex-col">
        <SectionTitle color={primaryColor}>
          {sections.catalogue.sectionTitle}
        </SectionTitle>
        <div set:html={sections.catalogue.description} class="font-medium text-base lg:text-[18px] max-w-lg pl-15" />
      </div>
      <img
        src={sections.catalogue.image}
        alt={sections.catalogue.imageAlt ?? `Catálogo ${brand.name}`}
        class="catalogue-image mt-5"
        loading="lazy"
      />
    </div>
  </section>

  <section class="events-section scrolling-section">
    <SectionTitle color={primaryColor}>
      {sections.events.sectionTitle}
    </SectionTitle>
    <div class="max-w-7xl mx-auto px-10">
      <p class="events-title font-extrabold max-w-2xl text-2xl lg:text-2xl text-justify tracking-tight mb-5">
        {sections.events.title}
      </p>
      <div class="events-grid grid lg:grid-cols-2 gap-10">
        <img
          src={sections.events.items[0].image}
          alt={sections.events.items[0].title}
          class="event-image w-full md:w-75 rounded-lg overflow-hidden"
          loading="lazy"
        />
        <div class="grid lg:grid-cols-2 gap-10">
          {
            sections.events.items
              .slice(1)
              .map((event: BusinessEventItem, idx: number) => (
                <img
                  src={event.image}
                  alt={event.title}
                  class="event-image w-full md:w-100 lg:w-125 max-lg:h-100 object-cover rounded-lg lg:aspect-video overflow-hidden"
                  data-index={idx + 1}
                  loading="lazy"
                />
              ))
          }
          <p class="events-description col-span-2 font-medium text-base lg:text-xl text-justify">
            {sections.events.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <MicrositeFooter
    logo={branding.logos.footer}
    brandName={brand.name}
    contact={footer.contact}
    footerTheme={footerTheme}
  />
</MicrositeLayout>

<style scoped>
  .catalogue-text,
  .catalogue-image {
    opacity: 0;
  }

  .events-title,
  .event-image,
  .events-description {
    opacity: 0;
  }

  .scrolling-section:has(iframe) {
    opacity: 0;
  }
</style>

<script>
  import './animations';
</script>
