---
import MicrositeLayout from '@/layouts/MicrositeLayout.astro';
import Navbar from '../components/Navbar.astro';
import SectionTitle from '../components/SectionTitle.astro';
import MicrositeFooter from '../components/MicrositeFooter.astro';
import HeroCarousel from './components/HeroCarousel';
import ProductCard from './components/ProductCard.astro';
import BannerSection from './components/BannerSection.astro';

import type {
  BusinessMicrositeConfig,
  ProductItem,
  BusinessEventItem,
  BusinessBannerTheme,
  BusinessProductCardTheme,
  BusinessProductCardCtaTheme,
  BusinessHeroCtaTheme,
  BusinessHeroTextTheme,
} from './types';
import EventsGallery from './components/EventsGallery.astro';

interface Props {
  config: BusinessMicrositeConfig;
}

const { config } = Astro.props;

const { brand, meta, branding, navigation, sections, footer, contact } = config;

const {
  primaryColor,
  accentColor,
  buttonColor,
  buttonHoverColor,
  buttons,
  surfaces,
  footer: footerTheme,
} = branding.theme;
const productCardTheme: BusinessProductCardTheme = surfaces?.productCard ?? {
  featuredBackground: '#20252E',
  defaultBackground: '#303640',
  textColor: '#FFFFFF',
};
const productCardCtaTheme: BusinessProductCardCtaTheme = buttons?.productCardCta ?? {
  background: '#FFFFFF',
  textColor: accentColor,
  hoverBackground: '#E2E8F0',
  hoverTextColor: accentColor,
  borderColor: 'transparent',
  hoverBorderColor: 'transparent',
};
const heroCtaTheme: BusinessHeroCtaTheme = buttons?.heroCta ?? {
  background: buttonColor,
  textColor: '#FFFFFF',
  hoverBackground: buttonHoverColor,
  hoverTextColor: '#FFFFFF',
  borderColor: accentColor,
  hoverBorderColor: accentColor,
};
const heroTextTheme: BusinessHeroTextTheme = branding.theme.hero?.text ?? {
  titleColor: '#FFFFFF',
  subtitleColor: '#FFFFFF',
  descriptionColor: 'rgba(255, 255, 255, 0.9)',
  sliderTitleColor: '#FFFFFF',
  sliderSubtitleColor: '#FFFFFF',
  sliderActiveBorderColor: '#FFFFFF',
};
const bannerTheme: BusinessBannerTheme = branding.theme.banner ?? {
  titleColor: '#FFFFFF',
  descriptionColor: '#FFFFFF',
  overlayBackground: 'rgba(0, 0, 0, 0.1)',
};

const heroItems = sections.heroes;
const productItems = sections.products.items;
const featuredProductIndexes = new Set([0, 5, 9]);
const baseProductItems = productItems.slice(0, 3);
const extraProductItems = productItems.slice(3);
const allProductsLabel = sections.products.allProductsLabel ?? 'Ver todos los productos';
const collapseProductsLabel = sections.products.collapseProductsLabel ?? 'Ver menos productos';
const productsToggleStyle = `--business-products-toggle-background: ${heroCtaTheme.background ?? buttonColor}; --business-products-toggle-text: ${heroCtaTheme.textColor ?? '#FFFFFF'}; --business-products-toggle-border: ${heroCtaTheme.borderColor ?? accentColor}; --business-products-toggle-hover-background: ${heroCtaTheme.hoverBackground ?? buttonHoverColor}; --business-products-toggle-hover-text: ${heroCtaTheme.hoverTextColor ?? '#FFFFFF'}; --business-products-toggle-hover-border: ${heroCtaTheme.hoverBorderColor ?? accentColor};`;
const videoSource = sections.video?.url;
const isDirectVideoSource = typeof videoSource === 'string' && /\.(mp4|webm|ogg|mov|m4v)(\?.*)?$/i.test(videoSource);

const getProductSlotClass = (itemIndex: number) => {
  switch (itemIndex) {
    case 0:
    case 5:
    case 9:
      return 'md:col-span-2 xl:col-span-6';
    case 6:
    case 7:
    case 8:
      return 'md:col-span-1 xl:col-span-2';
    default:
      return 'md:col-span-1 xl:col-span-3';
  }
};
---

<MicrositeLayout
  title={meta.title}
  description={meta.description}
  favicon={meta.favicon}
  whatsappUrl={contact?.whatsapp}
>
  <Navbar logo={branding.logos.header} basePath={navigation.basePath} items={navigation.items} />

  <div class="px-3 md:px-5">
    <HeroCarousel
      heroes={heroItems}
      theme={{ buttonColor, buttonHoverColor, accentColor, heroCta: heroCtaTheme, heroText: heroTextTheme }}
      buttonBorder={accentColor}
      client:load
    />
  </div>

  <section id="products">
    <SectionTitle color={primaryColor} class="business-products-title">
      {sections.products.sectionTitle}
    </SectionTitle>

    <div
      class="products-grid max-w-7xl mx-auto px-10 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-6 gap-5 mb-5"
      data-products-grid
    >
      {
        baseProductItems.map((item: ProductItem, index: number) => (
          <div class:list={[getProductSlotClass(index), 'h-full']}>
            <ProductCard
              {...item}
              accentColor={accentColor}
              buttonText={sections.products.buttonText}
              index={index}
              featured={featuredProductIndexes.has(index)}
              productCardTheme={productCardTheme}
              productCardCtaTheme={productCardCtaTheme}
            />
          </div>
        ))
      }

      {
        extraProductItems.length > 0 && (
          <div
            class="products-extra-shell md:col-span-2 xl:col-span-6 overflow-hidden"
            data-products-extra-shell
            hidden
          >
            <div
              class="products-extra-grid grid grid-cols-1 md:grid-cols-2 xl:grid-cols-6 gap-5 pt-5"
              data-products-extra-grid
            >
              {extraProductItems.map((item: ProductItem, index: number) => {
                const itemIndex = index + 3;

                return (
                  <div class:list={[getProductSlotClass(itemIndex), 'h-full']}>
                    <ProductCard
                      {...item}
                      accentColor={accentColor}
                      buttonText={sections.products.buttonText}
                      index={itemIndex}
                      featured={featuredProductIndexes.has(itemIndex)}
                      isExtra={true}
                      productCardTheme={productCardTheme}
                      productCardCtaTheme={productCardCtaTheme}
                    />
                  </div>
                );
              })}
            </div>
          </div>
        )
      }
    </div>

    {
      extraProductItems.length > 0 && (
        <div class="max-w-7xl mx-auto px-10 pb-8 flex justify-center">
          <button
            type="button"
            class="business-products-toggle"
            data-products-toggle
            data-expand-label={allProductsLabel}
            data-collapse-label={collapseProductsLabel}
            aria-expanded="false"
            style={productsToggleStyle}
          >
            {allProductsLabel}
          </button>
        </div>
      )
    }
  </section>

  {
    sections.video?.enabled && (
      <section class="grid place-items-center mb-5 " data-video-section>
        {isDirectVideoSource ? (
          <video
            class="w-full h-screen object-cover [&::-webkit-media-controls-fullscreen-button]:hidden"
            src={sections.video.url}
            poster={sections.video.poster}
            autoplay={sections.video.autoplay}
            muted={sections.video.muted ?? sections.video.autoplay}
            loop={sections.video.loop}
            controls={sections.video.controls ?? true}
            preload="metadata"
          />
        ) : (
          <iframe
            class="w-full h-[70dvh]"
            src={sections.video.url}
            title={sections.video.title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          />
        )}
      </section>
    )
  }

  <BannerSection {...sections.products.bannerProduct} brandName={brand.name} bannerTheme={bannerTheme} />

  <section class="catalogue-section">
    <div class="flex flex-col lg:flex-row justify-between">
      <div class="catalogue-text flex flex-col">
        <SectionTitle color={primaryColor} class="business-section-title">
          {sections.catalogue.sectionTitle}
        </SectionTitle>
        <div set:html={sections.catalogue.description} class="font-medium text-base lg:text-[18px] max-w-lg pl-15" />
      </div>
      <img
        src={sections.catalogue.image}
        alt={sections.catalogue.imageAlt ?? `Catálogo ${brand.name}`}
        class="catalogue-image mt-5"
        loading="lazy"
      />
    </div>
  </section>

  <EventsGallery events={sections.events} primaryColor={primaryColor} />

  <MicrositeFooter
    logo={branding.logos.footer}
    brandName={brand.name}
    contact={footer.contact}
    footerTheme={footerTheme}
  />
</MicrositeLayout>

<script>
  import './animations';
</script>

<style scoped>
  .business-products-toggle {
    background: var(--business-products-toggle-background);
    border-radius: 10px;
    color: var(--business-products-toggle-text);
    cursor: pointer;
    font-family: var(--font-plus-jakarta, 'Plus Jakarta Sans', sans-serif);
    font-size: 1rem;
    font-weight: 800;
    min-width: min(100%, 21rem);
    padding: 0.75rem 1.5rem;
    transition:
      background-color 0.32s ease,
      border-color 0.32s ease,
      color 0.32s ease,
      box-shadow 0.32s ease,
      transform 0.32s ease;
  }

  .business-products-toggle:hover,
  .business-products-toggle:focus-visible {
    background: var(--business-products-toggle-hover-background);
    border-color: var(--business-products-toggle-hover-border);
    box-shadow: 0 16px 28px rgba(15, 23, 42, 0.18);
    color: var(--business-products-toggle-hover-text);
    transform: translateY(-2px);
  }

  .business-products-toggle:focus-visible {
    outline: none;
  }
</style>
