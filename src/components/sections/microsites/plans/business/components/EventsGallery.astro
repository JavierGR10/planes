---
import '../../components/event-modal.css';
import { filterActiveEvents, getEventDateParts, getEventMeta } from '../../components/events-utils';
import SectionTitle from '../../components/SectionTitle.astro';
import type { BusinessEventsSectionConfig } from '../types';

interface Props {
  events: BusinessEventsSectionConfig;
  primaryColor: string;
}

const { events, primaryColor } = Astro.props as Props;
const visibleEvents = filterActiveEvents(events.items);

const modalId = 'business-event-modal';
const modalImageId = 'business-event-modal-image';
const modalTitleId = 'business-event-modal-title';
---

<section class="events-section">
  <SectionTitle color={primaryColor} class="events-title">
    {events.sectionTitle}
  </SectionTitle>

  <div class="max-w-7xl mx-auto px-10">
    <p class="events-title font-extrabold max-w-2xl text-2xl lg:text-2xl text-justify tracking-tight mb-5">
      {events.title}
    </p>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-3 my-10">
      {
        visibleEvents.length > 0 ? (
          visibleEvents.map((event, idx) => {
            const { day, month } = getEventDateParts(event.eventDate);
            const meta = getEventMeta(event);

            return (
              <button
                type="button"
                class="business-event-card group relative overflow-hidden rounded-lg cursor-pointer aspect-video"
                popovertarget={modalId}
                data-business-event-card
                data-event-date={event.eventDate}
                data-image={event.image}
                data-flyer={event.flyer}
                data-title={event.title}
                data-href={event.href}
              >
                <div class="business-event-card__date absolute left-4 top-4 z-10 rounded-2xl px-3 py-2 text-center text-white">
                  <span class="business-event-card__date-day block text-lg font-black leading-none">{day}</span>
                  <span class="business-event-card__date-month block text-[11px] font-bold tracking-[0.16em]">
                    {month}
                  </span>
                </div>

                <img
                  src={event.image}
                  alt={event.title}
                  class="event-image w-full h-full rounded-lg overflow-hidden object-cover transition-transform duration-500 group-hover:scale-105 will-change-transform"
                  data-index={idx + 1}
                  loading="lazy"
                />

                <div class="business-event-card__overlay absolute inset-0 flex items-end transition-opacity duration-300">
                  <div class="w-full p-4 text-left text-sm md:text-base text-white translate-y-full transition-transform duration-300 group-hover:translate-y-0">
                    <p class="font-bold">{event.title}</p>
                    {meta.length > 0 && (
                      <p class="business-event-card__meta mt-2 text-[11px] font-medium tracking-[0.12em] uppercase">
                        {meta.join(' · ')}
                      </p>
                    )}
                  </div>
                </div>
              </button>
            );
          })
        ) : (
          <p class="col-span-full text-center text-lg md:text-xl" data-business-events-empty>
            No hay eventos disponibles en este momento.
          </p>
        )
      }
    </div>

    {
      visibleEvents.length > 0 && (
        <p class="col-span-full hidden text-center text-lg md:text-xl" data-business-events-empty>
          No hay eventos disponibles en este momento.
        </p>
      )
    }

    <p class="events-description col-span-2 font-medium text-base lg:text-xl text-right">
      {events.description}
    </p>
  </div>

  <div id={modalId} popover class="business-event-modal event-modal-base">
    <figure class="relative grid place-items-center">
      <a target="_blank" rel="noopener noreferrer" class="business-event-modal__link">
        <img
          id={modalImageId}
          src=""
          alt=""
          class="max-h-[90vh] max-w-[90vw] rounded-2xl object-contain business-event-modal__image event-modal-image"
        />
      </a>

      <figcaption
        id={modalTitleId}
        class="absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full px-4 py-1 text-sm font-bold backdrop-blur business-event-modal__title event-modal-title"
      >
      </figcaption>

      <button
        popovertarget={modalId}
        popovertargetaction="hide"
        aria-label="Cerrar"
        class="absolute right-3 top-3 grid h-8 w-8 place-items-center rounded-full text-sm business-event-modal__close event-modal-close backdrop-blur ease-in-out duration-300 cursor-pointer"
      >
        ✕
      </button>
    </figure>
  </div>
</section>

<style>
  .business-event-card__overlay {
    background: linear-gradient(180deg, rgba(15, 23, 42, 0) 30%, rgba(15, 23, 42, 0.72) 100%);
  }

  .business-event-card__date {
    background: rgba(15, 23, 42, 0.7);
    min-width: 3.5rem;
  }

  .business-event-card__meta {
    color: rgba(255, 255, 255, 0.82);
  }

  .business-event-card:hover .business-event-card__overlay {
    opacity: 1;
  }
</style>

<script>
  import { setupEventModal } from '../../components/event-modal';
  import { setupEventVisibility } from '../../components/events-utils';

  setupEventModal({
    modalId: 'business-event-modal',
    imageId: 'business-event-modal-image',
    titleId: 'business-event-modal-title',
    cardSelector: '[data-business-event-card]',
    linkSelector: '.business-event-modal__link',
  });

  setupEventVisibility({
    cardSelector: '[data-business-event-card]',
    emptyStateSelector: '[data-business-events-empty]',
  });
</script>
