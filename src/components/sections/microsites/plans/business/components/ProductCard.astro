---
/**
 * ProductCard - Tarjeta de producto para el plan Business
 * Muestra información de producto con imagen, título, descripción y CTA
 */

import type { ProductItem } from '../types';
import type { BusinessProductCardCtaTheme, BusinessProductCardTheme } from '../types';

interface Props extends ProductItem {
  /** Color de acento para el botón */
  accentColor: string;
  /** Texto del botón de acción */
  buttonText: string;
  /** Índice del producto (para estilos condicionales) */
  index: number;
  productCardTheme?: BusinessProductCardTheme;
  productCardCtaTheme?: BusinessProductCardCtaTheme;
}

const {
  image,
  titleProduct,
  subtitleProduct,
  descriptionTitle,
  description,
  href = '#',
  accentColor,
  buttonText,
  index,
  productCardTheme,
  productCardCtaTheme,
} = Astro.props;

// El primer producto tiene un margen superior adicional en su CTA
const isFirst = index === 0;
const layoutClass = isFirst ? 'lg:col-span-2 justify-between flex-col lg:flex-row' : 'col-span-1 flex-col';
const surfaceColor = isFirst ? productCardTheme?.featuredBackground : productCardTheme?.defaultBackground;
const textColor = productCardTheme?.textColor;
const ctaBackground = productCardCtaTheme?.background;
const ctaTextColor = productCardCtaTheme?.textColor ?? accentColor;
const ctaHoverBackground = productCardCtaTheme?.hoverBackground;
const ctaHoverTextColor = productCardCtaTheme?.hoverTextColor ?? ctaTextColor;
const ctaBorderColor = productCardCtaTheme?.borderColor ?? 'transparent';
const ctaHoverBorderColor = productCardCtaTheme?.hoverBorderColor ?? ctaBorderColor;
---

<div
  class:list={[
    'product-card flex p-10 gap-5 rounded-[10px]',
    'transition-all duration-500 ease-out',
    'hover:-translate-y-2 hover:shadow-2xl hover:shadow-black/20',
    layoutClass,
  ]}
  data-index={index}
  style={`opacity: 0; background-color: ${surfaceColor}; color: ${textColor};`}
>
  <div class="flex flex-col gap-3">
    <h2 class="font-extrabold text-2xl lg:text-3xl">{titleProduct}</h2>
    <p class="font-medium text-sm lg:text-base whitespace-pre-line" set:html={subtitleProduct} />
  </div>

  <div class="flex-1 flex items-start justify-center">
    <img
      src={image}
      alt={titleProduct}
      class="h-70 object-contain transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
  </div>

  <div class:list={['flex flex-col justify-end items-end gap-3', isFirst && 'mt-20']}>
    <p class="font-bold text-base lg:text-xl max-w-xs text-right whitespace-pre-line">
      {descriptionTitle}
    </p>
    <p class="text-justify text-xs max-w-sm">
      {description}
    </p>
    <a
      href={href}
      class="product-cta w-fit mt-8 px-15 py-2 font-bold font-Jakarta text-sm lg:text-base cursor-pointer rounded-[10px] place-self-end hover:scale-105 hover:shadow-lg will-change-transform"
      style={`--business-product-cta-background: ${ctaBackground}; --business-product-cta-text-color: ${ctaTextColor}; --business-product-cta-hover-background: ${ctaHoverBackground}; --business-product-cta-hover-text-color: ${ctaHoverTextColor}; --business-product-cta-border-color: ${ctaBorderColor}; --business-product-cta-hover-border-color: ${ctaHoverBorderColor};`}
    >
      {buttonText}
    </a>
  </div>
</div>

<style>
  .product-cta {
    background: var(--business-product-cta-background);
    color: var(--business-product-cta-text-color);
    border: 1px solid var(--business-product-cta-border-color);
    transition:
      background-color 0.3s ease,
      color 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .product-cta:hover {
    background: var(--business-product-cta-hover-background);
    color: var(--business-product-cta-hover-text-color);
    border-color: var(--business-product-cta-hover-border-color);
  }
</style>
