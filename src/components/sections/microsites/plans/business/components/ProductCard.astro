---
/**
 * ProductCard - Tarjeta de producto para el plan Business
 * Muestra información de producto con imagen, título, descripción y CTA
 */

import type { ProductItem } from '../types';
import type { BusinessProductCardCtaTheme, BusinessProductCardTheme } from '../types';

interface Props extends ProductItem {
  /** Color de acento para el botón */
  accentColor: string;
  /** Texto del botón de acción */
  buttonText: string;
  /** Índice del producto (para estilos condicionales) */
  index: number;
  featured?: boolean;
  isExtra?: boolean;
  productCardTheme?: BusinessProductCardTheme;
  productCardCtaTheme?: BusinessProductCardCtaTheme;
}

const {
  image,
  titleProduct,
  subtitleProduct,
  descriptionTitle,
  description,
  href = '#',
  accentColor,
  buttonText,
  index,
  featured = false,
  isExtra = false,
  productCardTheme,
  productCardCtaTheme,
} = Astro.props as Props;

const layoutClass = featured ? 'justify-between flex-col lg:flex-row' : 'flex-col';
const surfaceColor = featured ? productCardTheme?.featuredBackground : productCardTheme?.defaultBackground;
const textColor = productCardTheme?.textColor;
const ctaBackground = productCardCtaTheme?.background;
const ctaTextColor = productCardCtaTheme?.textColor ?? accentColor;
const ctaHoverBackground = productCardCtaTheme?.hoverBackground;
const ctaHoverTextColor = productCardCtaTheme?.hoverTextColor ?? ctaTextColor;
const ctaBorderColor = productCardCtaTheme?.borderColor ?? 'transparent';
const ctaHoverBorderColor = productCardCtaTheme?.hoverBorderColor ?? ctaBorderColor;
---

<div
  class:list={['product-card flex h-full p-10 gap-5 rounded-[10px]', layoutClass]}
  data-index={index}
  data-product-extra={isExtra ? 'true' : 'false'}
  data-product-featured={featured ? 'true' : 'false'}
  style={`opacity: 0; background-color: ${surfaceColor}; color: ${textColor};`}
>
  <div class="product-card-copy flex flex-col gap-2">
    <h2 class="product-card-title font-extrabold text-2xl lg:text-3xl">{titleProduct}</h2>
    <p class="product-card-subtitle font-medium text-sm lg:text-base whitespace-pre-line" set:html={subtitleProduct} />
  </div>

  <div class="product-card-media flex-1 flex items-start justify-center">
    <img src={image} alt={titleProduct} class="product-card-image h-65 object-contain" loading="lazy" />
  </div>

  <div class:list={['product-card-meta mt-auto flex flex-col justify-end items-end gap-3', featured && 'lg:mt-20']}>
    {
      descriptionTitle && (
        <p class="product-card-description-title font-bold text-base lg:text-xl max-w-xs text-right">
          {descriptionTitle}
        </p>
      )
    }
    {description && <p class="product-card-description text-justify text-xs max-w-sm">{description}</p>}
    <a
      href={href}
      class="product-cta product-card-cta mt-4 px-15 py-2 font-bold font-Jakarta text-sm lg:text-base cursor-pointer rounded-[10px] self-end hover:shadow-lg will-change-transform"
      style={`--business-product-cta-background: ${ctaBackground}; --business-product-cta-text-color: ${ctaTextColor}; --business-product-cta-hover-background: ${ctaHoverBackground}; --business-product-cta-hover-text-color: ${ctaHoverTextColor}; --business-product-cta-border-color: ${ctaBorderColor}; --business-product-cta-hover-border-color: ${ctaHoverBorderColor};`}
    >
      <span class="product-cta-label">{buttonText}</span>
    </a>
  </div>
</div>

<style>
  .product-cta {
    align-items: center;
    background: var(--business-product-cta-background);
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0);
    color: var(--business-product-cta-text-color);
    border: 1px solid var(--business-product-cta-border-color);
    display: inline-flex;
    justify-content: center;
    isolation: isolate;
    min-width: 10rem;
    overflow: hidden;
    position: relative;
    transform-origin: right center;
    transition:
      background-color 0.3s ease,
      color 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .product-cta::before {
    background-color: var(--business-product-cta-hover-background);
    content: '';
    inset: 0;
    position: absolute;
    transform: translateX(-102%);
    transform-origin: left center;
    transition: transform 0.9s cubic-bezier(0.19, 1, 0.22, 1);
    z-index: -1;
  }

  .product-cta::after {
    content: '';
    inset: -0.4rem -0.65rem;
    position: absolute;
  }

  .product-cta-label,
  .product-cta-label {
    position: relative;
    z-index: 1;
  }

  .product-cta-label {
    transition: transform 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .product-cta:hover {
    color: var(--business-product-cta-hover-text-color);
    border-color: var(--business-product-cta-hover-border-color);
    box-shadow: 0 14px 28px rgba(15, 23, 42, 0.22);
  }

  .product-cta:hover::before,
  .product-cta:focus-visible::before {
    transform: translateX(0);
  }

  .product-cta:hover .product-cta-label,
  .product-cta:focus-visible .product-cta-label {
    transform: translateX(0.08rem);
  }

  .product-cta:focus-visible {
    border-color: var(--business-product-cta-hover-border-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--business-product-cta-hover-background) 35%, transparent 65%);
    color: var(--business-product-cta-hover-text-color);
    outline: none;
  }
</style>
