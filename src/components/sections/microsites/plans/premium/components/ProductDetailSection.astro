---
import type { PremiumProductDetailSection, PremiumProductFeature } from '../types';

interface Props {
  section: PremiumProductDetailSection;
  features?: PremiumProductFeature[];
  primaryColor: string;
  topSpacing?: boolean;
}

const { section, features = [], primaryColor, topSpacing = false } = Astro.props as Props;

const titleClassName = 'text-xl lg:text-2xl font-extrabold mb-5';
const paragraphClassName = 'text-lg lg:text-xl leading-relaxed font-semibold text-justify';
---

{
  section.variant === 'split' && (
    <div
      class={`premium-detail-section max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-10 lg:gap-16 ${topSpacing ? 'pt-10' : 'py-10'}`}
    >
      <div class="premium-detail-copy flex-1 tracking-[1px]">
        <h2 class={titleClassName}>{section.title}</h2>
        <div class="space-y-5 text-lg lg:text-xl leading-relaxed font-semibold text-justify">
          {section.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>

      {section.media?.[0] && (
        <div class="premium-detail-media flex-1 flex justify-center">
          <img
            src={section.media[0].src}
            alt={section.media[0].alt ?? section.title}
            class="w-full max-w-sm lg:max-w-md object-contain"
          />
        </div>
      )}
    </div>
  )
}

{
  section.variant === 'feature-list' && (
    <div class={`premium-detail-section max-w-7xl mx-auto tracking-[2px] ${topSpacing ? 'pt-10' : 'py-10'}`}>
      <div class="premium-detail-copy">
        <h2 class={titleClassName}>{section.title}</h2>

        {section.paragraphs.length > 0 && (
          <div class="space-y-5 mb-10">
            {section.paragraphs.map((paragraph) => (
              <p class={paragraphClassName}>{paragraph}</p>
            ))}
          </div>
        )}
      </div>

      <div class={`grid gap-10 my-10 ${section.media?.length || section.aside ? 'md:grid-cols-2' : 'grid-cols-1'}`}>
        {(section.media?.length || section.aside) && (
          <div class="flex-1 flex flex-col gap-15 justify-center">
            {section.media?.map((media) => (
              <img
                src={media.src}
                alt={media.alt ?? section.title}
                class="premium-detail-media w-full max-w-sm lg:max-w-md object-contain"
              />
            ))}

            {section.aside && (
              <div class="premium-detail-copy">
                <h2 class={titleClassName}>{section.aside.title}</h2>
                <div class="space-y-5">
                  {section.aside.paragraphs.map((paragraph) => (
                    <p class={paragraphClassName}>{paragraph}</p>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {features.length > 0 && (
          <ul class="flex-1 flex flex-col justify-center gap-4 text-sm md:text-base font-medium">
            {features.map((feature, index) => (
              <li class="premium-detail-feature-item flex items-start gap-3">
                <span
                  class="text-lg flex items-center justify-center rounded-full"
                  style={`color: ${primaryColor}; background-color: ${primaryColor}22; width: 40px; height: 40px;`}
                >
                  {index + 1}
                </span>
                <div class="flex flex-col gap-1">
                  <span class="font-semibold text-lg lg:text-xl">{feature.title}</span>
                  <span class="font-semibold opacity-70 text-sm lg:text-base">{feature.description}</span>
                </div>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  )
}

{
  section.variant === 'closing' && (
    <div class={`premium-detail-section ${topSpacing ? 'pt-10' : 'py-10'}`}>
      <div class="premium-detail-copy max-w-7xl mx-auto tracking-[2px]">
        <h2 class={titleClassName}>{section.title}</h2>
        <div class="space-y-5 mb-10">
          {section.paragraphs.map((paragraph) => (
            <p class={paragraphClassName}>{paragraph}</p>
          ))}
        </div>
      </div>

      {section.supportingBlocks?.length && (
        <div class="max-w-7xl mx-auto flex flex-col gap-10">
          {section.supportingBlocks.map((supportingBlock) => (
            <div class="premium-detail-support-block flex flex-col lg:flex-row items-center gap-5 ">
              <div class="premium-detail-copy flex-1 tracking-[2px]">
                <h2 class={titleClassName}>{supportingBlock.title}</h2>
                <div class="space-y-5">
                  {supportingBlock.paragraphs.map((paragraph) => (
                    <p class={paragraphClassName}>{paragraph}</p>
                  ))}
                </div>
                {supportingBlock?.bottomMedia &&
                  supportingBlock.bottomMedia.map((media) => (
                    <div class="premium-detail-media mt-10">
                      <img
                        src={media.src}
                        alt={media.alt ?? supportingBlock.title}
                        class="w-full max-w-sm lg:max-w-xl object-contain"
                      />
                    </div>
                  ))}
              </div>

              {supportingBlock.media?.[0] && (
                <div class="premium-detail-media flex-1 flex justify-center">
                  <img
                    src={supportingBlock.media[0].src}
                    alt={supportingBlock.media[0].alt ?? supportingBlock.title}
                    class="w-full max-w-sm lg:max-w-md object-contain"
                  />
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  )
}
