---
import type { PremiumPopupModalConfig } from '../types';

interface Props {
  popupModal: PremiumPopupModalConfig;
}

const { popupModal } = Astro.props as Props;
---

<div
  id="popup-overlay"
  class="premium-popup-overlay fixed inset-0 z-9999 flex items-center justify-center backdrop-blur-sm transition-opacity duration-300"
>
  <div
    id="popup-modal"
    class="popup-modal-content relative max-w-[1000px] w-[90%] max-h-[555px] rounded-[30px] overflow-hidden"
  >
    <button
      id="popup-close"
      class="premium-popup-close absolute cursor-pointer top-4 right-4 z-10 flex items-center justify-center w-10 h-10 rounded-full transition-colors duration-300"
      aria-label="Cerrar modal"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <a href={popupModal.href}>
      <img src={popupModal.image} alt={popupModal.alt} class="w-full h-full object-cover" loading="lazy" />
    </a>
  </div>
</div>

<style>
  .premium-popup-overlay {
    background: var(--premium-popup-overlay);
  }

  .premium-popup-close {
    background: var(--premium-popup-close-background);
    color: var(--premium-text-color);
  }

  .premium-popup-close:hover {
    background: var(--premium-popup-close-hover-background);
  }

  .popup-modal-content {
    clip-path: inset(50% 35% 50% 35% round 30px);
    transform: scale(0.85);
    opacity: 0;
    transition:
      clip-path 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .popup-modal-content.is-open {
    clip-path: inset(0% 0% 0% 0% round 30px);
    transform: scale(1);
    opacity: 1;
  }

  .popup-modal-content.is-closing {
    clip-path: inset(50% 50% 50% 50% round 30px);
    transform: scale(0.8);
    opacity: 0;
    transition:
      clip-path 0.4s cubic-bezier(0.32, 0, 0.67, 0),
      transform 0.4s cubic-bezier(0.32, 0, 0.67, 0),
      opacity 0.3s ease-in;
  }
</style>
