---
import type { PremiumProductBanner } from '../types';

interface Props extends PremiumProductBanner {
  brandName: string;
  bannerTheme?: {
    titleColor?: string;
    descriptionColor?: string;
    overlayBackground?: string;
  };
}

const { banner, image, title, description, brandName, bannerTheme } = Astro.props as Props;
const hasContent = Boolean(title || description || image);
const contentStyle = `color: ${bannerTheme?.descriptionColor ?? '#FFFFFF'};`;
const titleStyle = `color: ${bannerTheme?.titleColor ?? '#FFFFFF'};`;
const overlayStyle = `background: ${bannerTheme?.overlayBackground ?? 'var(--premium-service-card-overlay)'};`;
---

<section
  class="banner-section scrolling-section flex flex-col lg:flex-row justify-between items-center relative px-5 py-10 md:px-10 md:py-16 lg:p-20 min-h-125 lg:min-h-150 overflow-hidden mb-15"
  style={`background-image: url('${banner}');`}
>
  <div class="premium-banner-background absolute inset-0" aria-hidden="true"></div>

  {
    hasContent && (
      <>
        <div class="premium-banner-overlay absolute inset-0 z-0" style={overlayStyle} />

        <div
          class="banner-content relative z-10 text-center lg:text-left mb-8 lg:mb-0"
          style={`opacity: 0; ${contentStyle}`}
        >
          {title && (
            <h3 class="text-xl md:text-2xl lg:text-3xl font-extrabold mb-4" style={titleStyle}>
              {title}
            </h3>
          )}
          {description && (
            <p class="font-bold text-sm md:text-base lg:text-[18px] max-w-xl text-justify mx-auto lg:mx-0">
              {description}
            </p>
          )}
        </div>

        {image && (
          <img
            src={image}
            alt={title ?? `Banner ${brandName}`}
            class="banner-product relative z-10 w-full max-w-70 md:max-w-100 xl:max-w-150 object-contain"
            style="opacity: 0;"
            loading="lazy"
          />
        )}
      </>
    )
  }
</section>

<style>
  .banner-section {
    background-position: center;
    background-size: cover;
  }

  .premium-banner-background {
    background-image: inherit;
    background-position: inherit;
    background-size: inherit;
  }
</style>
