---
interface PopupModalData {
  image: string;
  alt: string;
  href: string;
}

interface PopupModalTheme {
  overlay?: string;
  closeBackground?: string;
  closeHoverBackground?: string;
}

interface Props {
  popupModal: PopupModalData;
  theme?: PopupModalTheme;
}

const { popupModal, theme } = Astro.props as Props;
const popupStorageKey = `microsite-popup:${popupModal.href}:${popupModal.image}`.replace(/[^a-zA-Z0-9:_-]/g, '_');
const popupDelayMs = 3500;
const popupCooldownMs = 24 * 60 * 60 * 1000;
const overlayStyle = `background: ${theme?.overlay ?? 'rgba(0, 0, 0, 0.72)'};`;
const closeStyle = `background: ${theme?.closeBackground ?? 'rgba(0, 0, 0, 0.45)'}; --microsite-popup-close-hover-background: ${theme?.closeHoverBackground ?? 'rgba(0, 0, 0, 0.72)'};`;
---

<div
  id="popup-overlay"
  class="microsite-popup-overlay fixed inset-0 z-9999 flex items-center justify-center px-4 backdrop-blur-sm transition-opacity duration-300"
  style={overlayStyle}
  data-popup-storage-key={popupStorageKey}
  data-popup-delay-ms={String(popupDelayMs)}
  data-popup-cooldown-ms={String(popupCooldownMs)}
  hidden
>
  <div
    id="popup-modal"
    class="microsite-popup-modal relative max-h-140 w-[92%] max-w-250 overflow-hidden rounded-[30px] shadow-[0_30px_90px_rgba(0,0,0,0.35)]"
  >
    <button
      id="popup-close"
      class="microsite-popup-close absolute right-4 top-4 z-10 flex h-10 w-10 cursor-pointer items-center justify-center rounded-full text-white transition-colors duration-300"
      aria-label="Cerrar modal"
      style={closeStyle}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <a href={popupModal.href}>
      <img src={popupModal.image} alt={popupModal.alt} class="h-full w-full object-cover" loading="lazy" />
    </a>
  </div>
</div>

<style>
  .microsite-popup-close:hover {
    background: var(--microsite-popup-close-hover-background);
  }

  .microsite-popup-modal {
    clip-path: inset(50% 35% 50% 35% round 28px);
    opacity: 0;
    transform: scale(0.85);
    transition:
      clip-path 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .microsite-popup-modal.is-open {
    clip-path: inset(0% 0% 0% 0% round 28px);
    opacity: 1;
    transform: scale(1);
  }

  .microsite-popup-modal.is-closing {
    clip-path: inset(50% 50% 50% 50% round 28px);
    opacity: 0;
    transform: scale(0.8);
    transition:
      clip-path 0.4s cubic-bezier(0.32, 0, 0.67, 0),
      transform 0.4s cubic-bezier(0.32, 0, 0.67, 0),
      opacity 0.3s ease-in;
  }
</style>

<script>
  const overlay = document.getElementById('popup-overlay');
  const closeBtn = document.getElementById('popup-close');
  const modal = document.getElementById('popup-modal');
  const popupLink = overlay?.querySelector('a');

  if (overlay && modal) {
    const storageKey = overlay.dataset.popupStorageKey ?? 'microsite-popup';
    const delayMs = Number(overlay.dataset.popupDelayMs ?? '3500');
    const cooldownMs = Number(overlay.dataset.popupCooldownMs ?? `${24 * 60 * 60 * 1000}`);

    const persistDismissal = () => {
      try {
        window.localStorage.setItem(storageKey, String(Date.now()));
      } catch {}
    };

    let lastDismissedAt = 0;

    try {
      lastDismissedAt = Number(window.localStorage.getItem(storageKey) ?? '0');
    } catch {}

    if (lastDismissedAt && Date.now() - lastDismissedAt < cooldownMs) {
      overlay.remove();
    } else {
      const openModal = () => {
        overlay.hidden = false;
        document.documentElement.style.overflow = 'hidden';
        document.body.style.overflow = 'hidden';

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            modal.classList.add('is-open');
          });
        });
      };

      const closeModal = () => {
        persistDismissal();
        modal.classList.remove('is-open');
        modal.classList.add('is-closing');

        window.setTimeout(() => {
          document.documentElement.style.overflow = '';
          document.body.style.overflow = '';
          overlay.classList.add('opacity-0');
          overlay.remove();
        }, 400);
      };

      window.setTimeout(openModal, delayMs);

      closeBtn?.addEventListener('click', closeModal);
      popupLink?.addEventListener('click', persistDismissal);

      overlay.addEventListener('click', (event) => {
        if (event.target === overlay) closeModal();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeModal();
      });
    }
  }
</script>
