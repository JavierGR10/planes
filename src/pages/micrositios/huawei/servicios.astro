---
import MicrositeLayout from '@/layouts/MicrositeLayout.astro';
import Navbar from '@/components/sections/microsites/plans/components/Navbar.astro';
import Footer from '@/components/sections/microsites/plans/professional/components/Footer.astro';
import Products from '@/components/sections/microsites/plans/professional/components/Products.astro';
import { huaweiConfig } from '../../../components/sections/microsites/config/config-by-plan/huawei.config';

const { meta, branding, navigation, sections, brand } = huaweiConfig;
const servicesSection = sections.services;
---

<MicrositeLayout title={meta.title} description={meta.description} favicon={meta.favicon}>
  <Navbar logo={branding.logos.header} basePath={navigation.basePath} items={navigation.items} />

  {
    servicesSection && (
      <Products
        title={servicesSection.title}
        subtitle={servicesSection.subtitle}
        items={servicesSection.items}
        theme={branding.theme}
        id="services"
      />
    )
  }

  <Footer logo={branding.logos.footer} brandName={brand.name} theme={branding.theme} />
</MicrositeLayout>

<script>
  import '@/components/sections/microsites/plans/professional/animations.ts';
</script>
