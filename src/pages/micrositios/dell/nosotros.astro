---
import Navbar from '@/components/sections/microsites/plans/components/Navbar.astro';
import PremiumFooter from '@/components/sections/microsites/plans/premium/components/PremiumFooter.astro';
import { resolvePremiumTheme } from '@/components/sections/microsites/plans/premium/theme';
import MicrositeLayout from '@/layouts/MicrositeLayout.astro';
import { getBrandConfig, isBrandPageEnabled } from '@/components/sections/microsites/config/brand-configs';

const dellConfig = getBrandConfig('dell');
const isAboutEnabled = isBrandPageEnabled('dell', 'about');
const { brand, meta, branding, navigation, footer, aboutPage, contact } = dellConfig;
const resolvedTheme = resolvePremiumTheme(branding.theme);
---

<MicrositeLayout
  title={aboutPage?.metaTitle ?? `Nosotros ${brand.name} - Grupo CVA`}
  description={aboutPage?.description ?? meta.description}
  favicon={meta.favicon}
  whatsappUrl={contact?.whatsapp}
>
  <div style={resolvedTheme.cssVars}>
    <div class="bg-[#1F242D] text-white min-h-screen">
      <Navbar
        logo={branding.logos.header}
        basePath={navigation.basePath}
        items={navigation.items}
        transparent={true}
        initialTone={resolvedTheme.navbar.initialTheme}
        scrollBackground={resolvedTheme.navbar.scrollBackground}
        scrollTone={resolvedTheme.navbar.scrollTheme}
      />

      {
        isAboutEnabled && aboutPage ? (
          <main class="max-w-7xl mx-auto px-6 md:px-10 lg:px-12 pt-30 md:pt-34 lg:pt-38 pb-18 md:pb-24 lg:pb-28">
            <section class="premium-secondary-hero space-y-6 md:space-y-8">
              <h1 class="premium-secondary-title text-4xl lg:text-5xl tracking-[5px] font-bold">{aboutPage.title}</h1>
              <p class="premium-secondary-subtitle text-lg lg:text-xl font-medium text-white text-justify">
                {aboutPage.description}
              </p>
            </section>

            <section class="premium-about-image-block mt-12 md:mt-16 lg:mt-18 pb-12 md:pb-16 lg:pb-35">
              <div class="relative">
                <img
                  src={aboutPage.image}
                  alt={aboutPage.imageAlt}
                  class="premium-about-image w-full h-80 md:h-115 lg:h-140 object-cover"
                  loading="lazy"
                />
                {/* <div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/15 to-transparent" /> */}
                <h2 class="premium-about-headline absolute left-0 bottom-5 md:bottom-8 lg:-bottom-19 max-w-lg whitespace-pre-line text-4xl md:text-6xl lg:text-[70px] font-bold leading-none tracking-tight">
                  {aboutPage.imageHeadline}
                </h2>
              </div>
            </section>

            <div class:list={['premium-detail-divider h-px w-full bg-[#828282]']} />

            <section class="premium-about-grid grid gap-8 md:gap-10 lg:grid-cols-2 lg:gap-16 pt-10 md:pt-12 lg:pt-14 items-start">
              <h3 class="premium-about-grid-title whitespace-pre-line text-3xl md:text-4xl lg:text-[50px] font-bold leading-tight tracking-tight">
                {aboutPage.gridTitle}
              </h3>
              <p class="premium-about-grid-copy text-lg md:text-xl font-medium leading-relaxed text-white text-justify">
                {aboutPage.gridDescription}
              </p>
            </section>
          </main>
        ) : (
          <section class="min-h-[60vh] flex items-center justify-center px-6 text-center">
            <div>
              <h1 class="text-3xl font-bold mb-4">Pagina no disponible</h1>
              <p class="text-white/70">La pagina Nosotros no esta habilitada para esta marca.</p>
            </div>
          </section>
        )
      }
    </div>

    <PremiumFooter footer={footer} footerTheme={resolvedTheme.footer} />
  </div>

  <script>
    import '@/components/sections/microsites/plans/premium/secondary-pages-animations';
  </script>
</MicrositeLayout>
