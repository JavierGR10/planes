---
import Layout from '../layouts/Layout.astro';

const PAGES = [
  {
    title: 'Huaweí',
    plan: 'Professional',
    href: '/micrositios/huawei',
  },
  {
    title: 'Dell',
    plan: 'Premium',
    href: '/micrositios/dell',
  },
  {
    title: 'Lenovo',
    plan: 'Business',
    href: '/micrositios/lenovo',
  },
];
---

<Layout>
  <main class="min-h-screen bg-[radial-gradient(circle_at_top,#d9f2ff_0%,#edf7fb_42%,#f7fbfd_100%)] px-6 py-10">
    <div class="mx-auto flex min-h-[calc(100vh-5rem)] max-w-6xl items-center justify-center">
      <div class="grid w-full max-w-5xl grid-cols-1 gap-6 md:grid-cols-3">
        {
          PAGES.map((page) => (
            <a
              href={page.href}
              target="_blank"
              class="group relative overflow-hidden rounded-3xl border border-cyan-100/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.96)_0%,rgba(227,244,252,0.95)_100%)] p-8 text-center shadow-[0_18px_45px_rgba(74,126,153,0.16)] transition duration-300 ease-out  hover:border-cyan-300 hover:shadow-[0_26px_65px_rgba(55,111,138,0.24)]"
            >
              <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(104,196,224,0.24),transparent_58%)] opacity-0 transition duration-300 group-hover:opacity-100" />
              <div class="relative flex min-h-55 flex-col items-center justify-center gap-4">
                <div class="flex flex-col items-center gap-1">
                  <span class="text-sm font-semibold uppercase tracking-[0.28em] text-cyan-700/70">Micrositio</span>
                  <span class="text-xs font-semibold uppercase text-cyan-500/70">{page.plan}</span>
                </div>
                <h2 class="text-3xl font-black tracking-tight text-slate-800">{page.title}</h2>
                <span class="inline-flex items-center rounded-full border border-cyan-200 bg-white/70 px-4 py-2 text-sm font-medium text-cyan-900 transition duration-300 group-hover:border-cyan-300 group-hover:bg-cyan-50">
                  Ver pagina
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </main>
</Layout>
