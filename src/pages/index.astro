---
import Layout from '../layouts/Layout.astro';
import { withBasePath } from '@/components/sections/microsites/config/path-utils';

const cvaLogo = withBasePath('/cva_logo.webp');
const cvaLogoLight = withBasePath('/cva_logo_letras_blancas.webp');

const NAV_ITEMS = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Planes', href: '#planes' },
  // { label: 'Contacto', href: '#contacto' },
];

const PAGES = [
  {
    title: 'Huawei',
    plan: 'Professional',
    href: withBasePath('/micrositios/huawei'),
    style: {
      titleGradient: 'from-[#2F3FA3] to-[#00aae8]',
      borderColor: 'border-white/90',
      hoverBorderColor: 'hover:border-[#7ed7ff]',
      planColor: 'text-[#1f49a5]/75',
      planBadge: 'border-[#bdd4ff] bg-[#eff5ff] text-[#1f49a5]',
      cardBackground: 'bg-[linear-gradient(180deg,rgba(255,255,255,0.96)_0%,rgba(233,242,255,0.98)_100%)]',
      glow: 'bg-[radial-gradient(circle_at_top,rgba(47,63,163,0.24),transparent_58%)]',
      ctaBorderColor: 'border-[#b8d8ff]',
      ctaHoverBorderColor: 'group-hover:border-[#7ed7ff]',
      ctaTextColor: 'text-[#16356d]',
      accentText: 'text-[#1f49a5]',
    },
  },
  {
    title: 'Dell',
    plan: 'Premium',
    href: withBasePath('/micrositios/dell'),
    featured: true,
    style: {
      titleGradient: 'from-[#00aae8] to-[#0AFFD8]',
      borderColor: 'border-[#00ffd6]',
      hoverBorderColor: 'hover:border-[#0AFFD8]',
      planColor: 'text-[#008fcc]/75',
      planBadge: 'border-[#5ff5df] bg-[#e7fffa] text-[#007fb0]',
      cardBackground: 'bg-[linear-gradient(180deg,rgba(255,255,255,0.98)_0%,rgba(220,252,248,0.95)_100%)]',
      glow: 'bg-[radial-gradient(circle_at_top,rgba(10,255,216,0.24),transparent_58%)]',
      ctaBorderColor: 'border-[#87f5e6]',
      ctaHoverBorderColor: 'group-hover:border-[#0AFFD8]',
      ctaTextColor: 'text-[#005f86]',
      accentText: 'text-[#007fb0]',
    },
  },
  {
    title: 'Lenovo',
    plan: 'Business',
    href: withBasePath('/micrositios/lenovo'),
    style: {
      titleGradient: 'from-[#2F3FA3] to-[#00aae8]',
      borderColor: 'border-white/90',
      hoverBorderColor: 'hover:border-[#7ed7ff]',
      planColor: 'text-[#1f49a5]/75',
      planBadge: 'border-[#bdd4ff] bg-[#eff5ff] text-[#1f49a5]',
      cardBackground: 'bg-[linear-gradient(180deg,rgba(255,255,255,0.98)_0%,rgba(235,244,255,0.97)_100%)]',
      glow: 'bg-[radial-gradient(circle_at_top,rgba(47,63,163,0.22),transparent_58%)]',
      ctaBorderColor: 'border-[#b8d8ff]',
      ctaHoverBorderColor: 'group-hover:border-[#7ed7ff]',
      ctaTextColor: 'text-[#16356d]',
      accentText: 'text-[#1f49a5]',
    },
  },
];
---

<Layout>
  <div
    data-preloader
    class="fixed inset-0 z-[80] flex items-center justify-center bg-[radial-gradient(circle_at_center,#1a406b_0%,#0b2035_48%,#06111d_100%)] px-6"
  >
    <div class="flex w-full max-w-sm flex-col items-center gap-6 text-center text-white">
      <img data-preloader-logo src={cvaLogoLight} alt="Grupo CVA" class="h-16 w-auto opacity-0 sm:h-20" />
      <div class="space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.4em] text-white/65">Micrositios CVA</p>
        <p class="text-sm text-white/80 sm:text-base">Preparando una experiencia enfocada en conversión y marca.</p>
      </div>
      <div class="h-px w-full overflow-hidden rounded-full bg-white/15">
        <div data-preloader-bar class="h-full origin-left scale-x-0 bg-linear-to-r from-[#00aae8] to-[#0AFFD8]"></div>
      </div>
    </div>
  </div>

  <main class="min-h-screen bg-[#eef7fb] text-slate-900">
    <header data-header class="sticky top-0 z-50 border-b border-white/55 bg-white/78 backdrop-blur-xl">
      <div
        class="mx-auto flex w-full max-w-6xl flex-wrap items-center justify-between gap-4 px-5 py-4 sm:px-8 lg:px-12"
      >
        <a href="#inicio" class="flex items-center gap-3">
          <img src={cvaLogo} alt="Grupo CVA" class="h-9 w-auto sm:h-10" />
          <div class="hidden min-[420px]:block">
            <p class="text-sm font-black uppercase tracking-[0.26em] text-[#0f3557]">Micrositios</p>
          </div>
        </a>

        <nav class="flex flex-wrap items-center justify-center gap-2 text-sm font-semibold text-slate-600 sm:gap-3">
          {
            NAV_ITEMS.map((item) => (
              <a
                href={item.href}
                class="rounded-full px-3 py-2 transition hover:bg-[#e7f6fb] hover:text-[#0a88bc] sm:px-4"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <section id="inicio" class="relative w-full overflow-hidden bg-gradient-to-b from-[#f3f8fc] via-white to-[#dff5ff]">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-32 bg-linear-to-b from-white/70 to-transparent"></div>
      <div
        class="pointer-events-none absolute left-1/2 top-24 h-64 w-64 -translate-x-1/2 rounded-full bg-[#00aae8]/12 blur-3xl"
      >
      </div>
      <div
        class="mx-auto grid w-full max-w-6xl gap-8 px-5 py-10 sm:px-8 sm:py-14 lg:grid-cols-[minmax(0,1.15fr)_minmax(280px,0.85fr)] lg:px-12 lg:py-18"
      >
        <div class="space-y-6">
          <div
            data-hero-copy
            class="inline-flex rounded-full border border-[#bde7f7] bg-white/80 px-4 py-2 text-xs font-bold uppercase tracking-[0.28em] text-[#0a88bc] shadow-sm"
          >
            Micrositios que captan atencion
          </div>
          <div class="space-y-5">
            <h1
              data-hero-title
              class="max-w-4xl text-4xl font-black leading-[0.95] tracking-tight text-[#0a2844] sm:text-5xl lg:text-6xl xl:text-[4.4rem]"
            >
              Impulsa marcas, despierta curiosidad y dirige la decision hacia tu plan ideal.
            </h1>
            <p data-hero-copy class="max-w-3xl text-base leading-relaxed text-slate-700 sm:text-lg lg:text-xl">
              Diseñamos micrositios que presentan tu marca con claridad comercial, elevan la percepción del cliente y lo
              conducen a explorar opciones con mayor intención de compra.
            </p>
          </div>

          <div data-hero-actions class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <a
              href="#planes"
              class="inline-flex items-center justify-center rounded-full bg-[#0c4a6e] px-6 py-3 text-sm font-bold uppercase tracking-[0.18em] text-white shadow-[0_18px_38px_rgba(12,74,110,0.22)] transition hover:bg-[#0a88bc]"
            >
              Explorar planes
            </a>
            <!-- <a
              href="#premium"
              class="inline-flex items-center justify-center rounded-full border border-[#87f5e6] bg-white px-6 py-3 text-sm font-bold uppercase tracking-[0.18em] text-[#0079a9] transition hover:border-[#0AFFD8] hover:bg-[#effffc]"
            >
              Priorizar premium
            </a> -->
          </div>

          <div data-hero-metrics class="grid max-w-3xl grid-cols-1 gap-3 sm:grid-cols-3">
            <div
              class="rounded-2xl border border-white/80 bg-white/75 px-5 py-4 shadow-[0_10px_30px_rgba(38,104,137,0.08)] backdrop-blur-sm"
            >
              <p class="text-2xl font-black text-[#0a88bc]">3</p>
              <p class="text-sm font-medium text-slate-600">niveles de alcance para distintos objetivos comerciales</p>
            </div>
            <div
              class="rounded-2xl border border-white/80 bg-white/75 px-5 py-4 shadow-[0_10px_30px_rgba(38,104,137,0.08)] backdrop-blur-sm"
            >
              <p class="text-2xl font-black text-[#0a88bc]">1</p>
              <p class="text-sm font-medium text-slate-600">ruta clara para destacar la propuesta premium</p>
            </div>
            <div
              class="rounded-2xl border border-white/80 bg-white/75 px-5 py-4 shadow-[0_10px_30px_rgba(38,104,137,0.08)] backdrop-blur-sm"
            >
              <p class="text-2xl font-black text-[#0a88bc]">100%</p>
              <p class="text-sm font-medium text-slate-600">foco en marca, producto y conversion comercial</p>
            </div>
          </div>
        </div>

        <aside data-hero-panel class="relative flex items-end">
          <div
            class="w-full rounded-[2rem] border border-white/80 bg-[linear-gradient(180deg,rgba(10,56,88,0.96)_0%,rgba(12,94,133,0.95)_52%,rgba(0,170,232,0.88)_100%)] p-6 text-white shadow-[0_28px_70px_rgba(7,63,100,0.22)] sm:p-8"
          >
            <div
              class="mb-8 inline-flex rounded-full border border-white/18 bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.28em] text-[#b8f8ff]"
            >
              Propuesta de valor
            </div>
            <h2 class="max-w-sm text-2xl font-black leading-tight sm:text-3xl">
              Descubre el plan que mejor eleva la presencia digital de tu marca.
            </h2>
            <p class="mt-4 max-w-sm text-sm leading-relaxed text-white/82 sm:text-base">
              Cada micrositio está diseñado para presentar tu propuesta con claridad, fortalecer tu imagen y facilitar
              que más clientes conozcan tus soluciones. Si buscas una experiencia más completa, visual y estratégica, el
              plan Premium ofrece el mayor nivel de personalización e impacto.
            </p>
            <div class="mt-8 space-y-3">
              <div class="flex items-center justify-between rounded-2xl border border-white/16 bg-white/10 px-4 py-3">
                <span class="text-sm font-semibold text-white/78">Marca con presencia</span>
                <span class="text-sm font-black uppercase tracking-[0.14em] text-white">Mayor recordacion</span>
              </div>
              <div
                class="flex items-center justify-between rounded-2xl border border-[#7ff6e6]/55 bg-[#dbfffa]/12 px-4 py-3"
              >
                <span class="text-sm font-semibold text-white/90">Experiencia premium</span>
                <span class="text-sm font-black uppercase tracking-[0.14em] text-[#b8fff2]">Mayor impacto</span>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section id="planes" class="w-full bg-linear-to-b from-[#07779e] via-[#2f8ab2] to-[#4380b9]">
      <div
        class="mx-auto flex w-full max-w-6xl flex-col gap-10 px-5 py-10 text-white sm:px-8 sm:py-12 lg:px-12 lg:py-16"
      >
        <div data-plan-intro class="mx-auto max-w-4xl text-center">
          <h2 class="mb-5 text-2xl font-extrabold tracking-wide sm:text-3xl lg:text-4xl xl:text-5xl">ESCOGE TU PLAN</h2>
          <p class="text-base leading-relaxed sm:text-lg lg:text-xl">
            En Grupo CVA creamos <span class="font-bold">Micrositios</span> diseñados para impulsar la presencia digital de
            tu negocio.
            <br class="hidden sm:block" />
            <br class="hidden sm:block" />
            Nuestras tres propuestas <span class="font-bold">—Professional, Business y Premium—</span> se adaptan a distintos
            niveles de alcance y personalización, brindándote desde soluciones funcionales hasta experiencias completas que
            fortalecen tu marca y conectan con tus clientes.
          </p>
        </div>

        <div class="mx-auto grid w-full max-w-5xl grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:items-stretch">
          {
            PAGES.map((page) => (
              <a
                id={page.featured ? 'premium' : undefined}
                data-card
                href={page.href}
                target="_blank"
                class={`group relative overflow-hidden rounded-3xl border 
                  ${page.style.borderColor ?? 'border-white'} 
                  ${page.style.hoverBorderColor ?? 'hover:border-white'} 
                  ${page.style.cardBackground ?? 'bg-white'} 
                  p-6 text-center shadow-[0_18px_45px_rgba(74,126,153,0.16)] 
                  transition duration-500 ease-out 
                  hover:shadow-[0_26px_65px_rgba(55,111,138,0.24)] 
                  sm:p-8 
                  ${
                    page.featured
                      ? 'lg:col-span-1 lg:-translate-y-3 lg:scale-[1.04] lg:shadow-[0_30px_80px_rgba(11,132,158,0.34)]'
                      : ''
                  }`}
              >
                {page.featured && (
                  <div class="absolute -right-11 top-6 z-10 w-40 rotate-45 bg-linear-to-r from-[#00aae8] to-[#0AFFD8] py-1.5 text-center shadow-md">
                    <span class="text-xs font-bold uppercase tracking-wider text-[#08344e]">Plan ideal</span>
                  </div>
                )}
                <div
                  class={`pointer-events-none absolute inset-0 ${page.style.glow} opacity-0 transition duration-300 group-hover:opacity-100`}
                />
                <div class="relative flex min-h-64 flex-col items-center justify-center gap-6 sm:min-h-72">
                  <div class="flex w-full flex-col items-center gap-3">
                    <span
                      class={`inline-flex rounded-full border px-4 py-2 text-xs font-black uppercase tracking-[0.22em] ${page.style.planBadge}`}
                    >
                      {page.plan}
                    </span>
                  </div>

                  <div class="space-y-2">
                    {/* <span class={`text-sm font-semibold uppercase tracking-[0.14em] ${page.style.planColor}`}>
                      DEMO
                    </span> */}
                    <h2
                      class={`bg-linear-to-r ${page.style.titleGradient} bg-clip-text text-3xl font-black tracking-tight text-transparent sm:text-4xl`}
                    >
                      {page.title}
                    </h2>
                  </div>

                  {/* <p class="max-w-xs text-sm leading-relaxed text-slate-600 sm:text-base">
                    {page.featured
                      ? 'La opcion con mayor impacto visual, profundidad de contenido y percepcion premium para la marca.'
                      : 'Una muestra clara del plan para presentar producto, propuesta y presencia comercial con rapidez.'}
                  </p> */}

                  <span
                    class={`inline-flex items-center rounded-full border ${page.style.ctaBorderColor} bg-white/70 px-4 py-2 text-sm font-medium ${page.style.ctaTextColor} transition duration-300 ${page.style.ctaHoverBorderColor} group-hover:bg-white`}
                  >
                    Ver sitio de muestra
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <footer id="contacto" data-footer class="w-full bg-[#071722] text-white">
      <div
        class="mx-auto grid w-full max-w-6xl gap-8 px-5 py-10 sm:px-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:px-12 lg:py-12"
      >
        <div class="space-y-4">
          <img src={cvaLogoLight} alt="Grupo CVA" class="h-10 w-auto" />
          <!-- <p class="max-w-2xl text-sm leading-relaxed text-white/72 sm:text-base">
            Una portada comercial debe captar atención rápido, presentar valor con claridad y dirigir al cliente hacia
            la alternativa más rentable. Aquí la marca demo atrae; el plan Premium convierte.
          </p> -->
        </div>

        <div class="flex flex-col gap-3 text-sm sm:items-start">
          <a href="#planes" class="font-semibold text-white/84 transition hover:text-[#0AFFD8]">Explorar planes</a>
          <a
            href={withBasePath('/micrositios/dell')}
            class="font-semibold text-white/84 transition hover:text-[#0AFFD8]">Ir al plan premium</a
          >
          <!-- <a href="mailto:contacto@grupocva.com" class="font-semibold text-white/84 transition hover:text-[#0AFFD8]">
            contacto@grupocva.com
          </a> -->
        </div>
      </div>
    </footer>
  </main>
</Layout>

<script>
  import { prefersReducedMotion, setupPlanGsap } from '@/components/sections/microsites/plans/gsap';

  const initSmoothScroll = () => {
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((anchor) => {
      if (anchor.dataset.smoothReady === 'true') {
        return;
      }

      anchor.dataset.smoothReady = 'true';

      anchor.addEventListener('click', (event) => {
        const href = anchor.getAttribute('href');

        if (!href || href === '#') {
          return;
        }

        const target = document.querySelector<HTMLElement>(href);

        if (!target) {
          return;
        }

        event.preventDefault();

        const header = document.querySelector<HTMLElement>('[data-header]');
        const headerOffset = header?.offsetHeight ?? 0;
        const top = target.getBoundingClientRect().top + window.scrollY - headerOffset - 12;
        const behavior = prefersReducedMotion() ? 'auto' : 'smooth';

        window.scrollTo({ top, behavior });
        window.history.replaceState({}, '', href);
      });
    });
  };

  const initHomeAnimations = () => {
    const preloader = document.querySelector('[data-preloader]');
    const preloaderLogo = document.querySelector('[data-preloader-logo]');
    const preloaderBar = document.querySelector('[data-preloader-bar]');

    if (!preloader) {
      return;
    }

    if (prefersReducedMotion()) {
      preloader.remove();
      return;
    }

    const { gsap, ScrollTrigger } = setupPlanGsap();
    const revealTargets = [
      '[data-header]',
      '[data-hero-title]',
      '[data-hero-copy]',
      '[data-hero-actions]',
      '[data-hero-metrics]',
      '[data-hero-panel]',
      '[data-plan-intro]',
      '[data-footer]',
    ];

    gsap.set(revealTargets, { autoAlpha: 0, y: 28 });
    gsap.set('[data-card]', { autoAlpha: 0, y: 42, scale: 0.98 });

    const introTimeline = gsap.timeline({ defaults: { ease: 'power3.out' } });

    introTimeline
      .fromTo(preloaderLogo, { autoAlpha: 0, y: 22, scale: 0.94 }, { autoAlpha: 1, y: 0, scale: 1, duration: 0.7 })
      .to(preloaderBar, { scaleX: 1, duration: 0.8 }, '-=0.2')
      .to(preloader, {
        autoAlpha: 0,
        duration: 0.85,
        onComplete: () => preloader.remove(),
      })
      .to(
        revealTargets,
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.08,
          clearProps: 'transform,opacity,visibility',
        },
        '-=0.15'
      );

    gsap.utils.toArray<HTMLElement>('[data-card]').forEach((card, index) => {
      gsap.to(card, {
        autoAlpha: 1,
        y: 0,
        scale: 1,
        duration: 0.75,
        delay: index * 0.05,
        ease: 'power3.out',
        clearProps: 'transform,opacity,visibility',
        scrollTrigger: {
          trigger: card,
          start: 'top 85%',
          once: true,
        },
      });
    });

    ScrollTrigger.refresh();
  };

  if (document.readyState === 'complete') {
    initSmoothScroll();
    initHomeAnimations();
  } else {
    window.addEventListener(
      'load',
      () => {
        initSmoothScroll();
        initHomeAnimations();
      },
      { once: true }
    );
  }
</script>
